<%- include('../../partials/header') %>
<%- include('../../partials/messages') %>
<a href="/admin/music" class="back-link">&larr; Back to music management</a>
<h2>Upload Track</h2>
<form action="/admin/music" method="post" enctype="multipart/form-data" class="admin-form">
  <label>Title: <input type="text" name="title" required></label>
  <label>Artist: <input type="text" name="artist"></label>
  <label>Album: <input type="text" name="album"></label>
  <label>Year: <input type="number" name="year"></label>
  <label>Description:<textarea name="description"></textarea></label>
  <label>Audio File: <input type="file" name="file" accept="audio/*" required></label>
  <label>Cover Image: <input type="file" name="cover" accept="image/*"></label>
  <label>Order Index: <input type="number" name="order_index"></label>
  <% if (playlists && playlists.length) { %>
    <label>Playlists:
      <select name="playlists" multiple size="4">
        <% playlists.forEach(p => { %>
          <option value="<%= p.id %>"><%= p.title %></option>
        <% }) %>
      </select>
    </label>
    <p style="font-size:0.8rem;color:#888;">(hold Ctrl/Cmd to select multiple)</p>
  <% } %>
  <button type="submit">Upload</button>
</form>
<%- include('../../partials/footer') %>