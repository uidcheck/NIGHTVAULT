<%- include('../../partials/header') %>
<%- include('../../partials/messages') %>
<a href="/admin/music" class="back-link">&larr; Back to music management</a>
<h2>Edit Track</h2>
<form action="/admin/music/<%= track.id %>?_method=PUT" method="post" enctype="multipart/form-data" class="admin-form">
  <label>Title: <input type="text" name="title" value="<%= track.title %>" required></label>
  <label>Artist: <input type="text" name="artist" value="<%= track.artist %>"></label>
  <label>Album: <input type="text" name="album" value="<%= track.album %>"></label>
  <label>Year: <input type="number" name="year" value="<%= track.year %>"></label>
  <label>Description:<textarea name="description"><%= track.description %></textarea></label>
  <label>Audio File: <input type="file" name="file" accept="audio/*"></label>
  <label>Cover Image: <input type="file" name="cover" accept="image/*"></label>
  <label>Order Index: <input type="number" name="order_index" value="<%= track.order_index %>"></label>
  <% if (playlists && playlists.length) { %>
    <label>Playlists:
      <select name="playlists" multiple size="4">
        <% playlists.forEach(p => { %>
          <option value="<%= p.id %>" <%= selectedPlaylists && selectedPlaylists.includes(p.id) ? 'selected' : '' %>><%= p.title %></option>
        <% }) %>
      </select>
    </label>
    <p style="font-size:0.8rem;color:#888;">(hold Ctrl/Cmd to select multiple)</p>
  <% } %>
  <button type="submit">Update</button>
</form>
<%- include('../../partials/footer') %>