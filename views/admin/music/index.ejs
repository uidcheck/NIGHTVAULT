<%- include('../../partials/header') %>
<%- include('../../partials/messages') %>
<a href="/admin" class="back-link">&larr; Back to dashboard</a>
<h2>Music Management</h2>
<a href="/admin/music/new" class="btn">Upload New Track</a>
<a href="/admin/music/batch" class="btn">Batch Upload</a>
<% if (tracks && tracks.length) { %>
  <section class="admin-bulk-root" data-bulk-select-root data-bulk-label-singular="song" data-bulk-label-plural="songs">
    <div class="admin-bulk-toolbar">
      <div class="admin-bulk-toolbar-actions">
        <button type="button" class="btn" data-bulk-select-start>Select Songs</button>
        <button type="button" class="btn" data-bulk-select-stop hidden>Stop Selecting</button>
      </div>
      <form id="music-bulk-delete-form" action="/admin/music/bulk-delete" method="post" class="admin-bulk-delete-form" data-bulk-delete-form data-no-soft-submit="true" hidden>
        <%- include('../../partials/csrf-field') %>
        <button type="button" class="btn admin-bulk-delete-btn" data-bulk-delete-button disabled>Delete Selected</button>
        <span class="admin-bulk-selection-count" data-bulk-selection-count>0 songs selected</span>
      </form>
    </div>
    <ul class="admin-list">
    <% tracks.forEach(t => { %>
      <li data-bulk-select-item>
        <label class="bulk-select-checkbox-wrap">
          <input type="checkbox" name="selected_ids" value="<%= t.id %>" data-bulk-select-checkbox form="music-bulk-delete-form">
          <span>Select</span>
        </label>
        <span class="item-title"><%= t.title %> by <%= t.artist %></span>
        <% const count = trackPlaylists[t.id] ? trackPlaylists[t.id].length : 0; %>
        <div class="admin-item-actions">
          <button type="button" class="toggle-membership">Playlists (<%= count %>)</button>
          <a href="/admin/music/<%= t.id %>/edit">edit</a> |
          <form action="/admin/music/<%= t.id %>?_method=DELETE" method="post" style="display:inline;">
            <%- include('../../partials/csrf-field') %>
            <button type="submit" class="link-button">delete</button>
          </form>
        </div>
        <div class="membership-panel" style="display:none;">
          <form method="post" action="/admin/music/<%= t.id %>/playlists">
            <%- include('../../partials/csrf-field') %>
            <% if (playlists && playlists.length) { %>
              <% playlists.forEach(p => { %>
                <label style="display:block; font-size:0.85rem;">
                  <input type="checkbox" name="playlists" value="<%= p.id %>" <%= trackPlaylists[t.id] && trackPlaylists[t.id].some(m=>m.id===p.id) ? 'checked' : '' %> > <%= p.title %>
                </label>
              <% }) %>
            <% } %>
            <button type="submit" class="btn">Save</button>
          </form>
        </div>
      </li>
    <% }) %>
    </ul>
    <%- include('../../partials/admin-bulk-confirm-modal') %>
  </section>
<% } else { %>
  <p>No tracks yet.</p>
<% } %>
<%- include('../../partials/footer') %>