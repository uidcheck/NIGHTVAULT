<%- include('../../partials/header') %>
<%- include('../../partials/messages') %>
<a href="/admin/music" class="back-link">&larr; Back to music management</a>
<h2>Batch Upload Music</h2>
<form action="/admin/music/batch" method="post" enctype="multipart/form-data" class="admin-form" id="batch-upload-form" data-no-soft-submit="true" data-upload-progress-form data-upload-processing-label="Upload complete. Processing files..." data-upload-processing-label-wav="Upload complete. Converting WAV files to MP3 and finalising batch..." data-upload-files-label-singular="track" data-upload-files-label-plural="tracks">
  <%- include('../../partials/csrf-field') %>
  <label>Audio Files: <input type="file" name="files" accept="audio/*" multiple required></label>
  <p style="font-size:0.8rem;color:#888;">Select multiple audio files to upload at once. Metadata will be auto-extracted where available.</p>
  <section class="upload-feedback" data-upload-feedback hidden aria-live="polite" aria-atomic="true">
    <div class="upload-feedback-header">
      <h3 data-upload-feedback-title>Preparing batch upload</h3>
      <span class="upload-feedback-phase" data-upload-feedback-phase>Waiting to start</span>
    </div>
    <div class="upload-feedback-bar" aria-hidden="true">
      <span data-upload-feedback-bar></span>
    </div>
    <div class="upload-feedback-meta">
      <strong data-upload-feedback-percent>0%</strong>
      <span data-upload-feedback-detail>Select files and upload to see progress.</span>
    </div>
    <div class="upload-feedback-processing" data-upload-feedback-processing hidden>
      <span class="upload-feedback-spinner" aria-hidden="true"></span>
      <span data-upload-feedback-processing-text>Processing upload...</span>
    </div>
    <p class="upload-feedback-error" data-upload-feedback-error hidden></p>
  </section>

  <h3>Shared Album Details</h3>
  <label>Shared Artist: <input type="text" name="default_artist" placeholder="e.g. Artist Name"></label>
  <label>Shared Album: <input type="text" name="default_album"></label>
  <label>Shared Year: <input type="number" name="default_year"></label>
  <label>Shared Description: <textarea name="shared_description" placeholder="Album description (shown at playlist level)"></textarea></label>
  <label>Shared Cover Image: <input type="file" name="shared_cover" accept="image/*"></label>
  <p style="font-size:0.8rem;color:#888;">One cover image for the whole batch. If not provided, embedded covers from files will be used.</p>

  <h3>Playlist Assignment</h3>
  <label>Assign to Existing Playlist:
    <select name="playlist_id">
      <option value="">-- None --</option>
      <% if (playlists && playlists.length) { %>
        <% playlists.forEach(p => { %>
          <option value="<%= p.id %>"><%= p.title %></option>
        <% }) %>
      <% } %>
    </select>
  </label>
  <p>or</p>
  <label>Create New Playlist: <input type="text" name="new_playlist_title" placeholder="e.g. My Album"></label>

  <button type="submit">Upload Batch</button>
</form>
<%- include('../../partials/footer') %>