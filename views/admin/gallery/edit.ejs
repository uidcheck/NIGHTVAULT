<%- include('../../partials/header') %>
<%- include('../../partials/messages') %>
<a href="/admin/gallery" class="back-link">&larr; Back to gallery management</a>
<h2>Edit Image</h2>
<form action="/admin/gallery/<%= img.id %>?_method=PUT" method="post" enctype="multipart/form-data" class="admin-form">
  <label>Title: <input type="text" name="title" value="<%= img.title %>"></label>
  <label>Caption:<textarea name="caption"><%= img.caption %></textarea></label>
  <label>Category: <input type="text" name="category" value="<%= img.category %>"></label>
  <label>Image File: <input type="file" name="file" accept="image/*"></label>
  <% if (collections && collections.length) { %>
    <label>Collections:
      <select name="collections" multiple size="4">
        <% collections.forEach(c => { %>
          <option value="<%= c.id %>" <%= collectionIds && collectionIds.includes(c.id) ? 'selected' : '' %>><%= c.title %></option>
        <% }) %>
      </select>
    </label>
    <p style="font-size:0.8rem;color:#888;">(hold Ctrl/Cmd to select multiple)</p>
  <% } %>
  <button type="submit">Update</button>
</form>
<%- include('../../partials/footer') %>