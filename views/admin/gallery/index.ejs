<%- include('../../partials/header') %>
<%- include('../../partials/messages') %>
<a href="/admin" class="back-link">&larr; Back to dashboard</a>
<h2>Gallery Management</h2>
<a href="/admin/gallery/new" class="btn">Upload Image</a>
<% if (images && images.length) { %>
  <section class="admin-bulk-root" data-bulk-select-root data-bulk-label-singular="image" data-bulk-label-plural="images">
    <div class="admin-bulk-toolbar">
      <div class="admin-bulk-toolbar-actions">
        <button type="button" class="btn" data-bulk-select-start>Select Images</button>
        <button type="button" class="btn" data-bulk-select-stop hidden>Stop Selecting</button>
      </div>
      <form id="gallery-bulk-delete-form" action="/admin/gallery/bulk-delete" method="post" class="admin-bulk-delete-form" data-bulk-delete-form data-no-soft-submit="true" hidden>
        <%- include('../../partials/csrf-field') %>
        <button type="button" class="btn admin-bulk-delete-btn" data-bulk-delete-button disabled>Delete Selected</button>
        <span class="admin-bulk-selection-count" data-bulk-selection-count>0 images selected</span>
      </form>
    </div>
    <ul class="admin-list">
    <% images.forEach(img => { %>
      <li data-bulk-select-item>
        <label class="bulk-select-checkbox-wrap">
          <input type="checkbox" name="selected_ids" value="<%= img.id %>" data-bulk-select-checkbox form="gallery-bulk-delete-form">
          <span>Select</span>
        </label>
        <span class="item-title"><%= img.title || img.filename %></span>
        <% const count = imageCollections[img.id] ? imageCollections[img.id].length : 0; %>
        <div class="admin-item-actions">
          <button type="button" class="toggle-membership">Collections (<%= count %>)</button>
          <a href="/admin/gallery/<%= img.id %>/edit">edit</a> |
          <form action="/admin/gallery/<%= img.id %>?_method=DELETE" method="post" style="display:inline;">
            <%- include('../../partials/csrf-field') %>
            <button type="submit" class="link-button">delete</button>
          </form>
        </div>
        <div class="membership-panel" style="display:none;">
          <form method="post" action="/admin/gallery/<%= img.id %>/collections">
            <%- include('../../partials/csrf-field') %>
            <% if (collections && collections.length) { %>
              <% collections.forEach(c => { %>
                <label style="display:block; font-size:0.85rem;">
                  <input type="checkbox" name="collections" value="<%= c.id %>" <%= imageCollections[img.id] && imageCollections[img.id].some(m=>m.id===c.id) ? 'checked' : '' %> > <%= c.title %>
                </label>
              <% }) %>
            <% } %>
            <button type="submit" class="btn">Save</button>
          </form>
        </div>
      </li>
    <% }) %>
    </ul>
    <%- include('../../partials/admin-bulk-confirm-modal') %>
  </section>
<% } else { %>
  <p>No images yet.</p>
<% } %>
<%- include('../../partials/footer') %>