<%- include('../../partials/header') %>
<%- include('../../partials/messages') %>
<a href="/admin/projects" class="back-link">&larr; Back to project management</a>
<h2>Create Project</h2>
<form action="/admin/projects" method="post" enctype="multipart/form-data" class="admin-form">
  <label>Title: <input type="text" name="title" required></label>
  <label>Summary:<textarea name="summary"></textarea></label>
  <label>Description:<textarea name="description"></textarea></label>
  <label>Status: <input type="text" name="status"></label>
  <label>Tags: <input type="text" name="tags"></label>
  <label>Hero Image: <input type="file" name="hero_image" accept="image/*"></label>
  <label>Documents: <input type="file" name="documents" accept=".pdf,.doc,.docx,.txt" multiple></label>  <% if (collections && collections.length) { %>
    <label>Collections:
      <select name="collections" multiple size="4">
        <% collections.forEach(c => { %>
          <option value="<%= c.id %>"><%= c.title %></option>
        <% }) %>
      </select>
    </label>
    <p style="font-size:0.8rem;color:#888;">(hold Ctrl/Cmd to select multiple)</p>
  <% } %>  <button type="submit">Create</button>
</form>
<%- include('../../partials/footer') %>