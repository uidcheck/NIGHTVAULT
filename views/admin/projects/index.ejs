<%- include('../../partials/header') %>
<%- include('../../partials/messages') %>
<a href="/admin" class="back-link">&larr; Back to dashboard</a>
<h2>Projects Management</h2>
<a href="/admin/projects/new" class="btn">New Project</a>
<a href="/admin/collections/projects" class="btn">Manage Collections</a>
<% if (projects && projects.length) { %>
  <section class="admin-bulk-root" data-bulk-select-root data-bulk-label-singular="project" data-bulk-label-plural="projects">
    <div class="admin-bulk-toolbar">
      <div class="admin-bulk-toolbar-actions">
        <button type="button" class="btn" data-bulk-select-start>Select Projects</button>
        <button type="button" class="btn" data-bulk-select-stop hidden>Stop Selecting</button>
      </div>
      <form id="projects-bulk-delete-form" action="/admin/projects/bulk-delete" method="post" class="admin-bulk-delete-form" data-bulk-delete-form data-no-soft-submit="true" hidden>
        <%- include('../../partials/csrf-field') %>
        <button type="button" class="btn admin-bulk-delete-btn" data-bulk-delete-button disabled>Delete Selected</button>
        <span class="admin-bulk-selection-count" data-bulk-selection-count>0 projects selected</span>
      </form>
    </div>
    <ul class="admin-list">
    <% projects.forEach(p => { %>
      <li data-bulk-select-item>
        <label class="bulk-select-checkbox-wrap">
          <input type="checkbox" name="selected_ids" value="<%= p.id %>" data-bulk-select-checkbox form="projects-bulk-delete-form">
          <span>Select</span>
        </label>
        <span class="item-title"><%= p.title %></span>
        <% const count = projectCollections[p.id] ? projectCollections[p.id].length : 0; %>
        <div class="admin-item-actions">
          <button type="button" class="toggle-membership">Collections (<%= count %>)</button>
          <a href="/admin/projects/<%= p.id %>/edit">edit</a> |
          <form action="/admin/projects/<%= p.id %>?_method=DELETE" method="post" style="display:inline;">
            <%- include('../../partials/csrf-field') %>
            <button type="submit" class="link-button">delete</button>
          </form>
        </div>
        <div class="membership-panel" style="display:none;">
          <form method="post" action="/admin/projects/<%= p.id %>/collections">
            <%- include('../../partials/csrf-field') %>
            <% if (collections && collections.length) { %>
              <% collections.forEach(c => { %>
                <label style="display:block; font-size:0.85rem;">
                  <input type="checkbox" name="collections" value="<%= c.id %>" <%= projectCollections[p.id] && projectCollections[p.id].some(m=>m.id===c.id) ? 'checked' : '' %> > <%= c.title %>
                </label>
              <% }) %>
            <% } %>
            <button type="submit" class="btn">Save</button>
          </form>
        </div>
      </li>
    <% }) %>
    </ul>
    <%- include('../../partials/admin-bulk-confirm-modal') %>
  </section>
<% } else { %>
  <p>No projects yet.</p>
<% } %>
<%- include('../../partials/footer') %>