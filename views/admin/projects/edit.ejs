<%- include('../../partials/header') %>
<%- include('../../partials/messages') %>
<a href="/admin/projects" class="back-link">&larr; Back to project management</a>
<h2>Edit Project</h2>
<form action="/admin/projects/<%= proj.id %>?_method=PUT" method="post" enctype="multipart/form-data" class="admin-form">
  <label>Title: <input type="text" name="title" value="<%= proj.title %>" required></label>
  <label>Summary:<textarea name="summary"><%= proj.summary %></textarea></label>
  <label>Description:<textarea name="description"><%= proj.description %></textarea></label>
  <label>Status: <input type="text" name="status" value="<%= proj.status %>"></label>
  <label>Tags: <input type="text" name="tags" value="<%= proj.tags %>"></label>
  <label>Hero Image: <input type="file" name="hero_image" accept="image/*"></label>
  <label>Additional Documents: <input type="file" name="documents" accept=".pdf,.doc,.docx,.txt" multiple></label>  <% if (collections && collections.length) { %>
    <label>Collections:
      <select name="collections" multiple size="4">
        <% collections.forEach(c => { %>
          <option value="<%= c.id %>" <%= collectionIds && collectionIds.includes(c.id) ? 'selected' : '' %>><%= c.title %></option>
        <% }) %>
      </select>
    </label>
    <p style="font-size:0.8rem;color:#888;">(hold Ctrl/Cmd to select multiple)</p>
  <% } %>  <button type="submit">Update</button>
</form>

<h3 style="margin-top: 2rem;">Add New Update</h3>
<form action="/admin/projects/<%= proj.id %>/updates" method="post" enctype="multipart/form-data" class="admin-form">
  <label>Update Content:<textarea name="content" required></textarea></label>
  <label>Attachments (optional): <input type="file" name="documents" accept=".pdf,.doc,.docx,.txt" multiple></label>
  <button type="submit">Add Update</button>
</form>

<h3 style="margin-top: 2rem;">Project Updates</h3>
<% if (updates && updates.length) { %>
  <ul class="admin-list">
    <% updates.forEach(u => { %>
      <li>
        <span class="update-timestamp"><%= new Date(u.created_at).toLocaleString() %></span>
        <span class="update-content"><%= u.content %></span>
        <% if (u.attachments && u.attachments.length) { %>
          <ul class="update-attachments">
            <% u.attachments.forEach(att => { %>
              <li><a href="/uploads/documents/<%= att.filename %>?t=<%= Date.now() %>" target="_blank"><%= att.original_name %></a></li>
            <% }) %>
          </ul>
        <% } %>
        <div class="update-actions">
          <form action="/admin/projects/<%= proj.id %>/updates/<%= u.id %>?_method=DELETE" method="post" style="display:inline;">
            <button type="submit" class="link-button" style="color: #a00; font-size: 0.85rem;">delete</button>
          </form>
        </div>
      </li>
    <% }) %>
  </ul>
<% } else { %>
  <p>No updates yet.</p>
<% } %>
<%- include('../../partials/footer') %>