<%- include('../../partials/header') %>
<%- include('../../partials/messages') %>
<a href="/admin/videos" class="back-link">&larr; Back to video management</a>
<h2>Add Video</h2>
<form action="/admin/videos" method="post" enctype="multipart/form-data" class="admin-form">
  <%- include('../../partials/csrf-field') %>
  <label>Title: <input type="text" name="title" required></label>
  <label>Description:<textarea name="description"></textarea></label>
  <label>Category: <input type="text" name="category"></label>
  <label>Video File: <input type="file" name="file" accept="video/*"></label>
  <label>Embed URL: <input type="text" name="embed_url" placeholder="https://..."></label>
  <% if (playlists && playlists.length) { %>
    <label>Playlists:
      <select name="playlists" multiple size="4">
        <% playlists.forEach(p => { %>
          <option value="<%= p.id %>"><%= p.title %></option>
        <% }) %>
      </select>
    </label>
    <p style="font-size:0.8rem;color:#888;">(hold Ctrl/Cmd to select multiple)</p>
  <% } %>
  <button type="submit">Save</button>
</form>
<%- include('../../partials/footer') %>