<%- include('../../partials/header') %>
<%- include('../../partials/messages') %>
<a href="/admin" class="back-link">&larr; Back to dashboard</a>
<h2>Video Management</h2>
<a href="/admin/videos/new" class="btn">Add Video</a>
<% if (videos && videos.length) { %>
  <section class="admin-bulk-root" data-bulk-select-root data-bulk-label-singular="video" data-bulk-label-plural="videos">
    <div class="admin-bulk-toolbar">
      <div class="admin-bulk-toolbar-actions">
        <button type="button" class="btn" data-bulk-select-start>Select Videos</button>
        <button type="button" class="btn" data-bulk-select-stop hidden>Stop Selecting</button>
      </div>
      <form id="videos-bulk-delete-form" action="/admin/videos/bulk-delete" method="post" class="admin-bulk-delete-form" data-bulk-delete-form data-no-soft-submit="true" hidden>
        <%- include('../../partials/csrf-field') %>
        <button type="button" class="btn admin-bulk-delete-btn" data-bulk-delete-button disabled>Delete Selected</button>
        <span class="admin-bulk-selection-count" data-bulk-selection-count>0 videos selected</span>
      </form>
    </div>
    <ul class="admin-list">
    <% videos.forEach(v => { %>
      <li data-bulk-select-item>
        <label class="bulk-select-checkbox-wrap">
          <input type="checkbox" name="selected_ids" value="<%= v.id %>" data-bulk-select-checkbox form="videos-bulk-delete-form">
          <span>Select</span>
        </label>
        <span class="item-title"><%= v.title %></span>
        <% const count = videoPlaylists[v.id] ? videoPlaylists[v.id].length : 0; %>
        <div class="admin-item-actions">
          <button type="button" class="toggle-membership">Playlists (<%= count %>)</button>
          <a href="/admin/videos/<%= v.id %>/edit">edit</a> |
          <form action="/admin/videos/<%= v.id %>?_method=DELETE" method="post" style="display:inline;">
            <%- include('../../partials/csrf-field') %>
            <button type="submit" class="link-button">delete</button>
          </form>
        </div>
        <div class="membership-panel" style="display:none;">
          <form method="post" action="/admin/videos/<%= v.id %>/playlists">
            <%- include('../../partials/csrf-field') %>
            <% if (playlists && playlists.length) { %>
              <% playlists.forEach(p => { %>
                <label style="display:block; font-size:0.85rem;">
                  <input type="checkbox" name="playlists" value="<%= p.id %>" <%= videoPlaylists[v.id] && videoPlaylists[v.id].some(m=>m.id===p.id) ? 'checked' : '' %> > <%= p.title %>
                </label>
              <% }) %>
            <% } %>
            <button type="submit" class="btn">Save</button>
          </form>
        </div>
      </li>
    <% }) %>
    </ul>
    <%- include('../../partials/admin-bulk-confirm-modal') %>
  </section>
<% } else { %>
  <p>No videos yet.</p>
<% } %>
<%- include('../../partials/footer') %>