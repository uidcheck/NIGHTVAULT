<%- include('../../partials/header') %>
<%- include('../../partials/messages') %>
<a href="/admin/videos" class="back-link">&larr; Back to video management</a>
<h2>Edit Video</h2>
<form action="/admin/videos/<%= video.id %>?_method=PUT" method="post" enctype="multipart/form-data" class="admin-form">
  <%- include('../../partials/csrf-field') %>
  <label>Title: <input type="text" name="title" value="<%= video.title %>" required></label>
  <label>Description:<textarea name="description"><%= video.description %></textarea></label>
  <label>Category: <input type="text" name="category" value="<%= video.category %>"></label>
  <label>Video File: <input type="file" name="file" accept="video/*"></label>
  <% if (video.filename) { %>
    <p style="font-size:0.8rem;color:#888; margin-top:-0.5rem;">Leave the file field empty to keep the current uploaded video, or choose a new file to replace it.</p>
  <% } else { %>
    <p style="font-size:0.8rem;color:#f2b8b8; margin-top:-0.5rem;">This record does not have a local video file. Upload one now to keep it, or delete the record.</p>
  <% } %>
  <% if (playlists && playlists.length) { %>
    <label>Playlists:
      <select name="playlists" multiple size="4">
        <% playlists.forEach(p => { %>
          <option value="<%= p.id %>" <%= selectedPlaylists && selectedPlaylists.includes(p.id) ? 'selected' : '' %>><%= p.title %></option>
        <% }) %>
      </select>
    </label>
    <p style="font-size:0.8rem;color:#888;">(hold Ctrl/Cmd to select multiple)</p>
  <% } %>
  <button type="submit">Update</button>
</form>
<%- include('../../partials/footer') %>