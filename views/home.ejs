<%- include('partials/header') %>
<%- include('partials/messages') %>
<section class="intro">
  <h2>Creative Archive</h2>
  <p>A collection of music, media and experimental projects.</p>
  <form action="/search" method="get" class="search-form">
    <input type="text" name="q" placeholder="Search music, videos, gallery, projects..." required>
    <button type="submit">Search</button>
  </form>
</section>
<section class="features">
  <div class="card">
    <h3>Music</h3>
    <p>Listen to tracks and albums.</p>
    <a href="/music" class="btn">Enter</a>
  </div>
  <div class="card">
    <h3>Videos</h3>
    <p>Watch a curated selection of video work.</p>
    <a href="/videos" class="btn">Enter</a>
  </div>
  <div class="card">
    <h3>Gallery</h3>
    <p>Browse images and visual pieces.</p>
    <a href="/gallery" class="btn">Enter</a>
  </div>
  <div class="card">
    <h3>Projects</h3>
    <p>Explore ongoing and past projects.</p>
    <a href="/projects" class="btn">Enter</a>
  </div>
</section>
<%
  const homepageLinkGroups = homepageLinks || { socials: [], other: [] };
  const socialLinks = homepageLinkGroups.socials || [];
  const otherLinks = homepageLinkGroups.other || [];
  const hasHomepageLinks = socialLinks.length || otherLinks.length;
%>
<% if (hasHomepageLinks) { %>
  <section class="homepage-link-sections" aria-label="Featured links">
    <% if (socialLinks.length) { %>
      <section class="homepage-link-section">
        <div class="homepage-link-section__header">
          <p class="homepage-link-section__eyebrow">Section</p>
          <h3>Socials</h3>
        </div>
        <div class="homepage-link-list">
          <% socialLinks.forEach((link) => { %>
            <div class="homepage-link-card">
              <a href="<%= link.url %>" class="homepage-link-card__link">
                <span class="homepage-link-card__title"><%= link.title %></span>
              </a>
              <% if (link.description) { %>
                <span class="homepage-link-card__description"><%= link.description %></span>
              <% } %>
            </div>
          <% }) %>
        </div>
      </section>
    <% } %>

    <% if (otherLinks.length) { %>
      <section class="homepage-link-section">
        <div class="homepage-link-section__header">
          <p class="homepage-link-section__eyebrow">Section</p>
          <h3>Other Links</h3>
        </div>
        <div class="homepage-link-list">
          <% otherLinks.forEach((link) => { %>
            <div class="homepage-link-card">
              <a href="<%= link.url %>" class="homepage-link-card__link">
                <span class="homepage-link-card__title"><%= link.title %></span>
              </a>
              <% if (link.description) { %>
                <span class="homepage-link-card__description"><%= link.description %></span>
              <% } %>
            </div>
          <% }) %>
        </div>
      </section>
    <% } %>
  </section>
<% } %>
<%- include('partials/footer') %>