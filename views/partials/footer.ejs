  </main>
  <footer>
    <p>&copy; <%= new Date().getFullYear() %> NIGHTVAULT</p>
  </footer>
  <% if (!(typeof hidePlayer !== 'undefined' && hidePlayer)) { %>
  <div id="audio-player" class="audio-player">
    <div class="controls">
      <div class="left-group">
        <button id="play-pause" type="button">Play</button>
        <button id="prev" type="button">Prev</button>
        <button id="next" type="button">Next</button>
        <span id="now-playing" class="now-playing-text">none</span>
      </div>
      <div class="middle-group">
        <div id="waveform"></div>
      </div>
      <div class="right-group">
        <div class="player-mode-controls" aria-label="Playback modes">
          <button id="shuffle-toggle" class="player-mode-button" type="button" aria-pressed="false">Shuffle</button>
          <button id="repeat-toggle" class="player-mode-button" type="button" data-repeat-mode="off" aria-pressed="false">Repeat Off</button>
        </div>
        <input type="range" id="volume" min="0" max="1" step="0.1" value="0.5">
        <span id="current-time">0:00</span> / <span id="duration">0:00</span>
        <label for="autoplay" class="autoplay-label">
          <input type="checkbox" id="autoplay">
          Autoplay
        </label>
      </div>
    </div>
  </div>
  <% } %>
  <script>
    (() => {
      function getCsrfToken() {
        const meta = document.querySelector('meta[name="csrf-token"]');
        return meta ? meta.content : '';
      }

      function shouldProtectForm(form) {
        if (!form) return false;

        const method = (form.getAttribute('method') || 'get').toUpperCase();
        if (method === 'GET' || method === 'HEAD' || method === 'OPTIONS') {
          return false;
        }

        const action = form.getAttribute('action') || window.location.href;
        const url = new URL(action, window.location.origin);
        return url.origin === window.location.origin;
      }

      function ensureCsrfField(form, token) {
        let field = form.querySelector('input[name="_csrf"]');
        if (!field) {
          field = document.createElement('input');
          field.type = 'hidden';
          field.name = '_csrf';
          form.appendChild(field);
        }
        field.value = token;
      }

      function applyCsrfProtection(root = document) {
        const token = getCsrfToken();
        if (!token || !root || !root.querySelectorAll) return;

        root.querySelectorAll('form').forEach((form) => {
          if (!shouldProtectForm(form)) return;
          ensureCsrfField(form, token);
        });
      }

      window.getCsrfToken = getCsrfToken;
      window.applyCsrfProtection = applyCsrfProtection;

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => applyCsrfProtection(document));
      } else {
        applyCsrfProtection(document);
      }
    })();
  </script>
  <script src="/js/main.js"></script>
</body>
</html>