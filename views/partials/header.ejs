<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NIGHTVAULT</title>
  <link rel="preload" as="image" href="/images/site-bg.webp" type="image/webp" fetchpriority="high">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://unpkg.com/wavesurfer.js"></script>
  <meta name="csrf-token" content="<%= csrfToken || '' %>">
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="shortcut icon" href="/favicon.png" type="image/png">
</head>
<body>
  <header>
    <h1 class="site-title"><a href="/">NIGHTVAULT</a></h1>
    <p class="tagline">Built on Feeling, Not Formula</p>
    <nav>
      <ul class="nav-list">
        <li><a href="/">Home</a></li>
        <li><a href="/music">Music</a></li>
        <li><a href="/videos">Videos</a></li>
        <li><a href="/gallery">Gallery</a></li>
        <li><a href="/projects">Projects</a></li>
        <% if (currentUser) { %>
          <li><a href="/admin">Dashboard</a></li>
          <li>
            <form action="/logout" method="post" style="display:inline;">
              <%- include('csrf-field') %>
              <button type="submit" class="link-button">Logout</button>
            </form>
          </li>
        <% } else if (adminSetupRequired) { %>
          <li><a href="/setup">Setup</a></li>
        <% } else { %>
          <li><a href="/login">Admin</a></li>
        <% } %>
      </ul>
    </nav>
  </header>
  <main>