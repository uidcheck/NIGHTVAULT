<%- include('partials/header') %>
<%- include('partials/messages') %>
<div style="max-width: 900px; margin: 0 auto;">
  <a href="/videos" style="color: #0ff; text-decoration: none;">← Back to videos</a>
  
  <h2><%= video.title %></h2>
  
  <% if (video.filename) { %>
    <div class="video-detail-player">
      <video id="detail-video" width="100%" height="100%" controls>
        <source src="/uploads/videos/<%= video.filename %>?t=<%= Date.now() %>" type="video/mp4">
        Your browser does not support the video tag.
      </video>
    </div>
  <% } %>
  
  <% if (video.description) { %>
    <section style="margin: 1.5rem 0;">
      <h3>Description</h3>
      <p><%= video.description %></p>
    </section>
  <% } %>
  
  <% if (video.category) { %>
    <section style="margin: 1.5rem 0; padding: 1rem; background: #111; border: 1px solid #333; border-radius: 4px;">
      <strong>Category:</strong> <span style="color: #0ff;"><%= video.category %></span>
    </section>
  <% } %>
  
  <section style="margin: 2rem 0; text-align: center;">
    <a href="/videos" class="search-form" style="background: #0ff; color: #000; padding: 0.6rem 1rem; text-decoration: none; border: none; cursor: pointer; display: inline-block;">Back to videos</a>
  </section>
</div>
<%- include('partials/footer') %>
