<%- include('partials/header') %>
<%- include('partials/messages') %>
<h2>Gallery</h2>
<form method="get" class="search-form">
  <input type="text" name="search" value="<%= search || '' %>" placeholder="Search gallery">
  <% if (selectedCollection) { %>
    <input type="hidden" name="collection" value="<%= selectedCollection %>">
  <% } %>
  <button type="submit">Search</button>
</form>
<div class="page-with-sidebar">
  <aside class="playlist-panel">
    <h3>Collections</h3>
    <div class="playlist-item">
      <a href="/gallery" class="playlist-link<%= !selectedCollection ? ' active' : '' %>">All Images</a>
    </div>
    <% if (collections && collections.length) { %>
      <% collections.forEach(col => { %>
        <div class="playlist-item">
          <a href="/gallery?collection=<%= col.id %>" class="playlist-link<%= selectedCollection == col.id ? ' active' : '' %>">
            <%= col.title %> (<%= col.count %>)
          </a>
        </div>
      <% }) %>
    <% } else { %>
      <p style="font-size:0.85rem; color:#777; margin-top:0.6rem;">No collections yet.</p>
    <% } %>
  </aside>

  <div class="gallery-main">
    <% if (images && images.length) { %>
      <div class="gallery-grid">
        <% images.forEach((img, index) => { %>
          <div class="gallery-item">
            <a href="/uploads/images/<%= img.filename %>">
              <img src="<%= getArchiveImageUrl('images', img.filename) %>" alt="<%= img.title %>" loading="<%= index < 6 ? 'eager' : 'lazy' %>" decoding="async" width="480" height="480">
            </a>
            <h3><%= img.title %></h3>
            <p><%= img.caption %></p>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p>No images yet.</p>
    <% } %>
  </div>
</div>
<%- include('partials/footer') %>